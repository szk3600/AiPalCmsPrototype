rules_version = '2';

/**
 * AiPal CMS Prototype: Cloud Storage Security Rules
 * ------------------------------------------------------------
 * パスの第1階層（フォルダ名）に基づいて、公開・非公開を厳格に判別します。
 */
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- ヘルパー関数 ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // --- ルール定義 ---

    /**
     * 全体パスの判定
     * allPaths[0] はパスの最初のフォルダ名（セグメント）を指します。
     */
    match /{allPaths=**} {
      
      // A. 公開ルール: 最初のフォルダ名が '_' で始まらない場合は誰でも読み取り可能
      // (例: brand/logo.png -> allPaths[0] は 'brand')
      allow read: if allPaths.size() > 0 && !allPaths[0].startsWith('_');
      
      // B. 共有保護ルール: _cms または _test フォルダはログイン済みなら読み取り可能
      allow read: if allPaths.size() > 0 && 
                  (allPaths[0] == '_cms' || allPaths[0] == '_test') && 
                  isAuthenticated();
      
      // C. 管理者ルール: 全ての書き込み、および全領域の読み取り権限
      allow write: if isAdmin();
      allow read: if isAdmin();
    }

    /**
     * ユーザー専用領域 (_users/)
     * match /{allPaths=**} よりも具体的なパス指定が優先されます。
     */
    match /_users/{userId}/{anyPath=**} {
      allow read, write: if isOwner(userId);
    }

    /**
     * システム領域 (_system/)
     */
    match /_system/{anyPath=**} {
      // 全体パスの match で isAdmin() が定義されているため、ここでは追加のガードのみ
      allow read, write: if isAdmin();
    }
  }
}